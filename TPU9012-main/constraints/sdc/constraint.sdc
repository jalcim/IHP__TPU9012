###############################################################################
# Created by write_sdc
###############################################################################
current_design TPU9012
###############################################################################
# Timing Constraints
###############################################################################
create_clock -name clk -period 8.0000 [get_pins {clk_pad/p2c}]
set_clock_transition 0.2500 [get_clocks {clk}]
set_clock_uncertainty 0.1500 clk
set_propagated_clock [get_clocks {clk}]
set_input_delay 0.0000 -clock [get_clocks {clk}] -min -add_delay [get_ports {data_in_PAD[0]}]
set_input_delay 2.4000 -clock [get_clocks {clk}] -max -add_delay [get_ports {data_in_PAD[0]}]
set_input_delay 0.0000 -clock [get_clocks {clk}] -min -add_delay [get_ports {data_in_PAD[1]}]
set_input_delay 2.4000 -clock [get_clocks {clk}] -max -add_delay [get_ports {data_in_PAD[1]}]
