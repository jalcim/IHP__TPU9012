set_input_delay 2.4000 -clock [get_clocks {clk}] -max -add_delay [get_ports {data_in_PAD[7]}]
set_input_delay 0.0000 -clock [get_clocks {clk}] -min -add_delay [get_ports {kernel_we_PAD}]
set_input_delay 2.4000 -clock [get_clocks {clk}] -max -add_delay [get_ports {kernel_we_PAD}]
set_input_delay 0.0000 -clock [get_clocks {clk}] -min -add_delay [get_ports {rst_n_PAD}]
set_input_delay 0.8000 -clock [get_clocks {clk}] -max -add_delay [get_ports {rst_n_PAD}]
set_output_delay 2.4000 -clock [get_clocks {clk}] -add_delay [get_ports {result_PAD[0]}]
set_output_delay 2.4000 -clock [get_clocks {clk}] -add_delay [get_ports {result_PAD[1]}]
set_output_delay 2.4000 -clock [get_clocks {clk}] -add_delay [get_ports {result_PAD[2]}]
set_output_delay 2.4000 -clock [get_clocks {clk}] -add_delay [get_ports {result_PAD[3]}]
set_output_delay 2.4000 -clock [get_clocks {clk}] -add_delay [get_ports {result_PAD[4]}]
set_output_delay 2.4000 -clock [get_clocks {clk}] -add_delay [get_ports {result_PAD[5]}]
set_output_delay 2.4000 -clock [get_clocks {clk}] -add_delay [get_ports {result_PAD[6]}]
set_output_delay 2.4000 -clock [get_clocks {clk}] -add_delay [get_ports {result_PAD[7]}]
set_false_path\
    -to [get_ports {alive_PAD}]
